{
  "name": "tex-board",
  "version": "1.0.0",
  "description": "TeX Board — a visual LaTeX node editor",
  "type": "module",
  "scripts": {
    "prepare":   "node scripts/copy-mathjax.mjs",
    "dev":       "npm run prepare && vite",
    "build":     "npm run prepare && tsc && vite build",
    "preview":   "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "mathjax": "^4.0.0"
  }
}